---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { marked } from 'marked';
import FormattedDate from '../components/FormattedDate.astro';

import {normalizePost, isPublished} from "./helpers.js";

const posts = (await getCollection('blog')).filter(isPublished).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).map(post => normalizePost(post));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* --- design knobs you can play with --- */
			main {
				width: 960px;            /* widen for the grid */
				max-width: calc(100% - 2em);
			}
			ul.posts {
				display: grid;
				grid-template-columns: repeat(2, 1fr);   /* two-wide; try 3 or 1 */
				gap: 2.5rem 2rem;
				list-style: none;
				margin: 1.5rem 0 0;
				padding: 0;
			}
			.card a.cover {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.card img {
				width: 100%;
				aspect-ratio: 16 / 9;     /* uniform thumbnail shape; tweak to taste */
				object-fit: cover;
				border-radius: 12px;
				margin-bottom: 0.75rem;
			}
			.card .title {
				margin: 0 0 0.2rem;
				font-size: 1.4rem;
				line-height: 1.15;
				color: rgb(var(--black));
			}
			.card .date {
				margin: 0 0 0.5rem;
				font-size: 0.95rem;
				color: rgb(var(--gray));
			}
			.card .desc {
				margin: 0;
				color: rgb(var(--gray-dark));
				/* clamp to keep cards balanced; remove to show full text */
				display: -webkit-box;
				-webkit-line-clamp: 4;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.card a.cover:hover .title { color: var(--accent); }
			.card a.cover:hover img { box-shadow: var(--box-shadow); }

			@media (max-width: 720px) {
				ul.posts {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Posts</h1>
			<ul class="posts">
				{
					posts.map((post) => (
						<li class="card">
							<a class="cover" href={`/${post.id}`}>
								{post.data.heroImage && (
									<Image
										src={post.data.heroImage}
										alt=""
										widths={[400, 800]}
										sizes="(max-width: 720px) 100vw, 460px"
									/>
								)}
								<h3 class="title">{post.data.title}</h3>
							</a>
							<p class="date"><FormattedDate date={post.data.pubDate} /></p>
							<p class="desc" set:html={marked.parseInline(post.data.description)} />
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
